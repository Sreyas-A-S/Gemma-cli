{
  "name": "gemma-cli",
  "version": "1.0.0",
  "description": "A local-first CLI for Gemma 4 models",
  "main": "dist/index.js",
  "bin": {
    "gemma": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "setup": "npm install && npm run build && tsx src/setup.ts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.6.1",
    "inquirer": "^9.3.8",
    "marked": "^18.0.3",
    "marked-terminal": "^7.3.0",
    "ollama": "^0.5.9",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/marked": "^5.0.2",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^20.12.12",
    "tsx": "^4.10.1",
    "typescript": "^5.4.5"
  },
  "type": "module"
}
